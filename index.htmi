<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VURA SHOP | Elevated Urban Staples</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
    
    <script src="https://www.paypal.com/sdk/js?client-id=Ac94A2-pGT_H7DVsKtG_50Yk53aXgR1aRj6hu_R69sODZirJqmlLj9KQQJu0Wv6IEEXHvUepgWZfoDtV&components=hosted-buttons"></script>

    <style>
        :root { --black: #0a0a0a; --white: #ffffff; }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; background: var(--white); color: var(--black); padding-bottom: 50px; }
        header { text-align: center; padding: 40px 20px; background: var(--black); color: var(--white); }
        header h1 { font-weight: 900; letter-spacing: 10px; font-size: 2rem; margin: 0; }
        .cart-bar { background: #f4f4f4; padding: 15px; display: flex; justify-content: center; border-bottom: 1px solid #ddd; position: sticky; top: 0; z-index: 1000; min-height: 80px; }
        .container { max-width: 1200px; margin: 40px auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 40px; padding: 0 20px; }
        .product-card { border: 1px solid #eee; padding: 20px; text-align: center; display: flex; flex-direction: column; background: #fff; border-radius: 4px; }
        .vura-gallery { display: grid; grid-template-columns: 2fr 1fr; gap: 10px; margin-bottom: 20px; }
        .vura-gallery img { width: 100%; height: 100%; object-fit: cover; background: #f9f9f9; }
        .img-main { grid-row: span 2; height: 350px !important; }
        .img-detail { height: 170px !important; }
        .title { font-weight: 700; font-size: 1.3rem; margin-top: 10px; min-height: 50px; }
        .price { font-weight: 900; font-size: 1.6rem; margin: 10px 0; }
        .paypal-slot { min-height: 100px; margin-top: auto; }
        footer { text-align: center; padding: 60px; color: #bbb; font-size: 0.7rem; letter-spacing: 3px; }
    </style>
</head>
<body>

<header><h1>VURA</h1></header>

<div class="cart-bar">
    <div id="pp-view-cart"></div>
</div>

<div class="container">
    <div class="product-card">
        <div class="vura-gallery">
            <img src="identity_front.jpg" class="img-main" alt="Vura Identity">
            <img src="identity_folded.jpg" class="img-detail">
            <img src="identity_model.jpg" class="img-detail">
        </div>
        <h2 class="title">VURA "Identity" - Onyx Black</h2>
        <p class="price">29,95€</p>
        <div id="paypal-1" class="paypal-slot"></div>
    </div>

    <div class="product-card">
        <div class="vura-gallery">
            <img src="identity_blue_front.jpg" class="img-main" alt="Vura Identity Blue">
            <img src="identity_blue_folded.jpg" class="img-detail">
            <img src="identity_blue_model.jpg" class="img-detail">
        </div>
        <h2 class="title">VURA "Identity" - Midnight Blue</h2>
        <p class="price">29,95€</p>
        <div id="paypal-2" class="paypal-slot"></div>
    </div>

    <div class="product-card">
        <div class="vura-gallery">
            <img src="gorra_frontal.jpg" class="img-main" alt="Vura Legacy Cap">
            <img src="gorra_detalle.jpg" class="img-detail">
            <img src="gorra_modelo.jpg" class="img-detail">
        </div>
        <h2 class="title">VURA "Legacy" Cap</h2>
        <p class="price">24,95€</p>
        <div id="paypal-3" class="paypal-slot"></div>
    </div>
</div>

<footer>© 2026 VURA - ELEVATED URBAN STAPLES</footer>

<script>
    // Script forzado para asegurar que PayPal cargue incluso en móviles lentos
    const checkPayPal = setInterval(function() {
        if (window.paypal && window.paypal.HostedButtons) {
            clearInterval(checkPayPal);
            
            // Renderizar botón de Ver Carrito
            paypal.HostedButtons({ hostedButtonId: "ZGPMBZCK6U9EC" }).render("#pp-view-cart");

            // Renderizar botones de productos
            paypal.HostedButtons({ hostedButtonId: "ZGPMBZCK6U9EC" }).render("#paypal-1");
            paypal.HostedButtons({ hostedButtonId: "LB5N2Z4F6M6QW" }).render("#paypal-2");
            paypal.HostedButtons({ hostedButtonId: "9MSMH2UPKVVS4" }).render("#paypal-3");
        }
    }, 1000);
</script>

</body>
</html>
